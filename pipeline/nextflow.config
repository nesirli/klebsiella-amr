params {
    metadata        = "${projectDir}/../data/metadata.csv"
    train_cutoff    = 2022
    test_years      = [2023, 2024]
    antibiotics     = ['meropenem', 'ciprofloxacin', 'ceftazidime', 'amikacin']

    max_samples     = -1  // -1 = all samples; cap for quick dev runs

    genome_size     = 5500000
    target_coverage = 100

    reference_url   = 'https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/240/185/GCF_000240185.1_ASM24018v2/GCF_000240185.1_ASM24018v2_genomic.fna.gz'
}

docker.enabled = true
outputDir       = 'results'

// Cap the local executor's total resource pool so concurrent tasks'
// declared memory/cpus are queued rather than oversubscribed (this is
// dev-machine capacity, e.g. colima's VM -- not the host's). No effect
// under -profile awsbatch, which uses the awsbatch executor instead.
// Nextflow logs "Unrecognized config option" for this $local block on
// every run -- confirmed benign: verified the values ARE read/enforced
// (a task requesting more than 6 cpus was correctly rejected, and an
// 8-sample run stayed under the 12GB cap with zero OOM kills).
executor {
    $local {
        cpus   = 6
        memory = '12 GB'
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    awsbatch {
        process.executor  = 'awsbatch'
        process.queue     = params.aws_queue
        aws.region        = params.aws_region
        aws.batch.cliPath = '/opt/aws-cli/bin/aws'
        workDir           = params.aws_workdir
    }
}
